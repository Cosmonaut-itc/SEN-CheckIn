{
  "extends": "../../packages/typescript-config/expo.json",
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@sen-checkin/api-contract": [
        "../../packages/api-contract/src"
      ],
      "@sen-checkin/api-contract/*": [
        "../../packages/api-contract/src/*"
      ],
      "@sen-checkin/api": [
        "../../apps/api/src"
      ],
      "@sen-checkin/api/*": [
        "../../apps/api/src/*"
      ],
      "@sen-checkin/types": [
        "../../packages/types/src/index.ts"
      ],
      "@sen-checkin/types/*": [
        "../../packages/types/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "types/**/*.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
