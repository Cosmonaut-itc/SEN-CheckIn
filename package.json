{
	"name": "sen-checkin",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"test:api:unit": "cd apps/api && bun run test:unit",
		"test:api:contract": "cd apps/api && bun run test:contract",
		"test:web:unit": "cd apps/web && bun run test",
		"test:web:e2e": "cd apps/web && bun run test:e2e",
		"test:ci": "bun run test:api:unit && bun run test:api:contract && bun run test:web:unit && bun run test:web:e2e && bun run lint && bun run check-types",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo run check-types",
		"dev:api": "turbo run dev --filter=@sen-checkin/api",
		"dev:mobile": "turbo run dev --filter=mobile",
		"build:api": "turbo run build --filter=@sen-checkin/api",
		"start:api": "turbo run start --filter=@sen-checkin/api",
		"build:mobile": "turbo run build --filter=mobile",
		"lint:api": "turbo run lint --filter=@sen-checkin/api",
		"lint:mobile": "turbo run lint --filter=mobile",
		"check-types:api": "turbo run check-types --filter=@sen-checkin/api",
		"check-types:mobile": "turbo run check-types --filter=mobile",
		"dev:web": "turbo run dev --filter=@sen-checkin/web",
		"build:web": "turbo run build --filter=@sen-checkin/web",
		"lint:web": "turbo run lint --filter=@sen-checkin/web",
		"check-types:web": "turbo run check-types --filter=@sen-checkin/web",
		"add:api": "bun add --cwd apps/api",
		"add:mobile": "bun add --cwd apps/mobile",
		"add:web": "bun add --cwd apps/web",
		"db:gen": "cd apps/api && bunx --bun drizzle-kit generate --config drizzle.config.ts",
		"db:mig": "cd apps/api && bunx --bun drizzle-kit migrate --config drizzle.config.ts",
		"db:seed": "cd apps/api && bun run db:seed",
		"db:reset": "cd apps/api && bun run db:reset"
	},
	"devDependencies": {
		"eslint": "^9.39.1",
		"prettier": "^3.6.2",
		"turbo": "^2.8.10",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18",
		"bun": ">=1.3.3"
	},
	"packageManager": "bun@1.3.3",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"trustedDependencies": [
		"unrs-resolver"
	],
	"overrides": {
		"react": "19.1.0",
		"react-dom": "19.1.0"
	},
	"resolutions": {
		"react": "19.1.0",
		"react-dom": "19.1.0"
	},
	"dependencies": {
		"better-auth": "^1.3.34"
	}
}
