{
	"name": "sen-checkin",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo run check-types"
	},
	"devDependencies": {
		"eslint": "^9.39.1",
		"prettier": "^3.6.2",
		"turbo": "^2.6.1",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.2.14",
	"workspaces": ["apps/*", "packages/*"]
}
