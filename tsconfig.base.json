{
	"extends": "./packages/typescript-config/base.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@sen-checkin/types": ["packages/types/src/index.ts"],
			"@sen-checkin/types/legal-template-defaults": [
				"packages/types/src/legal-template-defaults.ts"
			],
			"@sen-checkin/types/*": ["packages/types/src/*"],
			"@sen-checkin/design-tokens": ["packages/design-tokens/src/index.ts"],
			"@sen-checkin/design-tokens/*": ["packages/design-tokens/src/*"],
			"@sen-checkin/api": ["apps/api/src"],
			"@sen-checkin/api/*": ["apps/api/src/*"],
			"@sen-checkin/api-contract": ["packages/api-contract/src"],
			"@sen-checkin/eslint-config/*": ["packages/eslint-config/*"],
			"@sen-checkin/typescript-config/*": ["packages/typescript-config/*"],
			"@sen-checkin/web": ["apps/web"],
			"@sen-checkin/web/*": ["apps/web/*"]
		}
	},
	"include": ["apps", "packages", "documentacion"]
}
